# 런타임 환경
NODE_ENV=development
APP_PORT=3000
TZ=Asia/Seoul
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Dashboard 제공 방식
# single: Express가 정적 대시보드까지 함께 서빙
# separate: API 서버만 실행, 프론트는 별도 서버에서 운영
DASHBOARD_SERVE_MODE=single
DASHBOARD_STATIC_DIR=./dashboard/public
SOCKET_NAMESPACE=/monitoring

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_MODE=both
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/webhooks/telegram
TELEGRAM_SECRET_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Assistant Router (Phase 1)
# local_rule: 로컬 규칙 기반 분기, hybrid: 추후 LLM 보조 분류 확장용
ASSISTANT_ROUTER_MODE=local_rule
ASSISTANT_SHOW_REASONING=true
RAG_DEFAULT_LIMIT=5
RAG_SNIPPET_MAX_CHARS=240

# Assistant LLM (Phase 2)
# none: 생성형 응답 비활성화, ollama: 로컬 Ollama, gemini_cli: 추후 CLI 브리지
ASSISTANT_LLM_PROVIDER=ollama
ASSISTANT_LLM_SYSTEM_PROMPT=
ASSISTANT_HISTORY_LIMIT=8

# Docker 컨테이너에서 Host Ollama 접근 시 host.docker.internal 권장
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3
OLLAMA_REQUEST_TIMEOUT_MS=45000

# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_PARENT_PAGE_ID=
NOTION_SERVICE_WORKER_SECRET=your_notion_service_worker_secret
NOTION_LOG_ENABLED=false

# n8n (AI_Writer_TISTORY)
N8N_BLOG_TRIGGER_WEBHOOK_URL=https://your-n8n-host/webhook/blog-trigger
N8N_BLOG_CALLBACK_BASE_PATH=/webhooks/n8n
N8N_BLOG_CALLBACK_ROUTE=/blog/status
N8N_BLOG_CALLBACK_SECRET=your_n8n_callback_secret
N8N_CALLBACK_SECRET_HEADER=X-N8N-SECRET

# SQLite(vec)
SQLITE_DB_PATH=./storage/sqlite/ai_biseo.db
SQLITE_VEC_EXTENSION_PATH=
